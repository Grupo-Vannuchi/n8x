// Prisma schema for the n8x marketing platform.
// Bilingual content is stored as JSON maps shaped like { "pt": "...", "en": "..." }
// and resolved per-request via src/lib/i18n helpers. See src/lib/content.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime connection. On Supabase use the pooled (Supavisor/pgBouncer) URL on
  // port 6543 with `?pgbouncer=true`. Locally it's the direct Postgres URL.
  url      = env("DATABASE_URL")
  // Direct connection used by `prisma migrate`/`db push` (migrations can't run
  // through the transaction pooler). On Supabase this is the 5432 direct URL;
  // locally it's the same as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  EDITOR
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

// ---------------------------------------------------------------------------
// Marketing content (managed via the admin CMS)
// ---------------------------------------------------------------------------

/// A service the agency offers (social media, branding, etc.).
model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  icon        String // lucide-react icon name, e.g. "Megaphone"
  title       Json // LocalizedText
  description Json // LocalizedText
  content     Json     @default("{}") // LocalizedRichText (array of paragraphs per locale)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, featured, order])
  @@map("services")
}

/// An informational entry (knowledge base / "Informações"): listed in the navbar
/// burger menu and rendered as a standalone article with a sidebar of siblings.
model Information {
  id          String   @id @default(cuid())
  slug        String   @unique
  icon        String // lucide-react icon name, e.g. "Info"
  image       String   @default("") // thematic cover image URL (shown on the card)
  title       Json // LocalizedText
  description Json // LocalizedText
  content     Json     @default("{}") // LocalizedRichText (array of paragraphs per locale)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, featured, order])
  @@map("informations")
}

/// A portfolio case study.
model Project {
  id         String   @id @default(cuid())
  slug       String   @unique
  clientName String
  category   Json // LocalizedText
  year       Int
  coverImage String
  gallery    String[] @default([])
  tags       String[] @default([])
  title      Json // LocalizedText
  summary    Json // LocalizedText
  content    Json // LocalizedRichText (array of paragraphs per locale)
  featured   Boolean  @default(false)
  published  Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, featured, order])
  @@map("projects")
}

/// A client logo shown in the "they trust us" strip.
model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

/// A client testimonial / quote.
model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  company    String
  avatarUrl  String?
  rating     Int      @default(5)
  role       Json // LocalizedText
  quote      Json // LocalizedText
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

/// A member of the team.
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  photoUrl  String?
  socials   Json     @default("{}") // { instagram?, linkedin?, ... }
  role      Json // LocalizedText
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_members")
}

/// A headline statistic / animated counter.
model Stat {
  id        String   @id @default(cuid())
  key       String   @unique // "years", "logos", "clients", "ads"
  value     Int
  suffix    String   @default("")
  label     Json // LocalizedText
  order     Int      @default(0)
  published Boolean  @default(true)

  @@map("stats")
}

// ---------------------------------------------------------------------------
// Leads (contact + careers form submissions)
// ---------------------------------------------------------------------------

enum LeadType {
  CONTACT
  CAREER
}

enum LeadStatus {
  NEW
  CONTACTED
  ARCHIVED
}

model Lead {
  id        String     @id @default(cuid())
  type      LeadType   @default(CONTACT)
  status    LeadStatus @default(NEW)
  name      String
  email     String
  phone     String?
  company   String? // for CONTACT
  role      String? // desired role, for CAREER
  portfolio String? // link, for CAREER
  message   String
  tags      String[]   @default([]) // free-form labels applied by admins for triage
  locale    String     @default("pt")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([type, status, createdAt])
  @@map("leads")
}

// ---------------------------------------------------------------------------
// Funnels (link-shared conversational lead-capture quizzes)
// ---------------------------------------------------------------------------
// Funnels are single-language (the `locale` is chosen at creation and all copy
// is stored as plain strings, NOT the bilingual LocalizedText JSON used by the
// marketing CMS). They are public but unlisted: never in nav/sitemap, noindex.

enum FunnelType {
  MEETING // ends with a Google Calendar scheduler
  BONUS // ends with a button to download a PDF
  MESSAGE // ends by sending a WhatsApp message
}

enum FunnelStatus {
  DRAFT
  PUBLISHED
}

enum FunnelOutcome {
  COMPLETED
  MEETING_BOOKED
  BONUS_DOWNLOADED
  MESSAGE_SENT
}

enum WhatsappStatus {
  PENDING
  SENT
  FAILED
}

/// A conversational lead-capture quiz, shared via direct link. Single-language.
model Funnel {
  id     String       @id @default(cuid())
  slug   String       @unique
  locale String       @default("pt") // "pt" | "en", chosen at creation
  name   String // internal admin label
  type   FunnelType
  status FunnelStatus @default(DRAFT)

  /// Editable snapshot of the standard lead-capture opening (FunnelDefaultStep[]),
  /// copied from the global FunnelDefaultTemplate at creation and overridable.
  defaultBlock Json @default("[]")

  /// Personalized WhatsApp sent on completion. Supports {NOME} / {CARGO} tokens.
  completionMessage String

  // --- MEETING config ---
  meetingDurationMinutes Int?    @default(30)
  meetingSlotStartHour   Int?    @default(9) // local time, meetingTimezone
  meetingSlotEndHour     Int?    @default(18)
  meetingDaysAhead       Int?    @default(14)
  meetingTimezone        String? @default("America/Sao_Paulo")

  // --- BONUS config ---
  bonusUrl         String? // Google Drive PDF link
  bonusButtonLabel String?

  // --- MESSAGE config ---
  messageBody String? // WhatsApp body sent at the end (MESSAGE type)

  questions   FunnelQuestion[]
  submissions FunnelSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
  @@map("funnels")
}

/// A custom single-choice (buttons) question that runs after the default block.
model FunnelQuestion {
  id       String   @id @default(cuid())
  funnelId String
  funnel   Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  order    Int      @default(0)
  prompt   String
  options  String[] @default([]) // ordered single-choice labels

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([funnelId, order])
  @@map("funnel_questions")
}

/// A completed run of a funnel by one visitor (the captured lead + answers).
model FunnelSubmission {
  id       String @id @default(cuid())
  funnelId String
  funnel   Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  // Captured by the default block
  name      String
  role      String? // {CARGO}
  phone     String? // raw as entered
  phoneE164 String? // normalized for WhatsApp
  email     String?

  /// Custom-question answers: [{ questionId, prompt, answer }]
  answers Json @default("[]")

  outcome FunnelOutcome @default(COMPLETED)

  // MEETING
  meetingStartAt DateTime?
  googleEventId  String?

  // WhatsApp completion-message delivery
  whatsappStatus WhatsappStatus @default(PENDING)
  whatsappError  String?

  /// Client-generated idempotency key — guards against double submits.
  submissionToken String @unique

  locale    String   @default("pt")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([funnelId, createdAt])
  @@map("funnel_submissions")
}

/// OAuth tokens for the single company Google account (one row). Used by
/// MEETING funnels to read free/busy and create calendar events.
model GoogleAccount {
  id           String    @id @default(cuid())
  email        String? // connected account, for display
  accessToken  String?
  refreshToken String? // the durable credential
  expiryDate   DateTime?
  calendarId   String    @default("primary")
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("google_account")
}

/// Editable GLOBAL default lead-capture block — one row per locale. The admin
/// "edit default" screen edits this; new funnels copy `steps` into defaultBlock.
model FunnelDefaultTemplate {
  id        String   @id @default(cuid())
  locale    String   @unique // "pt" | "en"
  steps     Json     @default("[]") // FunnelDefaultStep[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("funnel_default_templates")
}
